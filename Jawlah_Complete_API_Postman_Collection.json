{
  "info": {
    "name": "Jawlah App - Complete API Collection",
    "description": "All APIs in one collection. Folders:\n\n**1. Public (No Authorization)** – No Bearer token needed.\n**2. Protected (Authorization Required)** – Use Bearer token (set accessToken after login).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "phone", "value": "+1234567890", "type": "string" },
    { "key": "otp", "value": "", "type": "string" },
    { "key": "fcmToken", "value": "firebase-generated-token-string", "type": "string" },
    { "key": "notificationId", "value": "", "type": "string" },
    { "key": "categoryId", "value": "1", "type": "string" },
    { "key": "vendorId", "value": "1", "type": "string" },
    { "key": "branchId", "value": "1", "type": "string" },
    { "key": "subcategoryId", "value": "1", "type": "string" },
    { "key": "productId", "value": "1", "type": "string" },
    { "key": "reviewId", "value": "1", "type": "string" },
    { "key": "offerId", "value": "1", "type": "string" },
    { "key": "variationId", "value": "1", "type": "string" },
    { "key": "userId", "value": "1", "type": "string" }
  ],
  "auth": { "type": "noauth" },
  "item": [
    {
      "name": "1. Public (No Authorization)",
      "description": "These endpoints do NOT require Authorization header. Use them without a token.",
