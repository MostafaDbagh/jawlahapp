              "name": "Request OTP for Phone Login",
              "request": {
                "auth": { "type": "noauth" },
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{\n  \"phone\": \"{{phone}}\"\n}" },
                "url": { "raw": "{{baseUrl}}/api/v1/auth/request-otp-login", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "request-otp-login"] }
              }
