    {
      "name": "2. Protected (Authorization Required)",
      "description": "These endpoints require Authorization: Bearer <token>. Set accessToken (e.g. from Login or Verify OTP and Login) in collection variables.",
      "item": [
        {
          "name": "Auth (Protected)",
          "item": [
            {
              "name": "Get Profile",
              "request": {
                "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
                "method": "GET",
                "header": [],
                "url": { "raw": "{{baseUrl}}/api/v1/auth/profile", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "profile"] }
              }
            },
            {
              "name": "Update Profile",
              "request": {
                "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
                "method": "PUT",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"username\": \"updateduser\",\n  \"full_name\": \"John Doe\",\n  \"phone_number\": \"509876543\",\n  \"profile_image\": \"https://example.com/avatar.jpg\",\n  \"preferred_language\": \"en\",\n  \"timezone\": \"UTC\"\n}"
                },
                "url": { "raw": "{{baseUrl}}/api/v1/auth/profile", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "profile"] }
              }
            },
            {
              "name": "Logout",
              "request": {
                "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
                "method": "POST",
                "header": [],
                "url": { "raw": "{{baseUrl}}/api/v1/auth/logout", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "logout"] }
